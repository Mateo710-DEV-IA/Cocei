PORT=3000

# SQL Server
# Host o IP del servidor SQL Server
DB_HOST=localhost
# Puerto de SQL Server (normalmente 1433)
DB_PORT=1433
# Nombre de la base de datos
DB_NAME=tu_base
# Usuario SQL (o usuario de autenticacion integrada si aplica)
DB_USER=UserCoceiDB
# Password del usuario SQL
DB_PASSWORD=Cocei@2026$.
# true si tu SQL requiere conexion cifrada TLS
DB_ENCRYPT=true
# true si usas certificado autofirmado en desarrollo
DB_TRUST_CERT=false

# ------------------------------------------------------------
# GOOGLE (SEPARADO POR TIPO DE CUENTA)
# ------------------------------------------------------------
# 1) CREDENCIALES TECNICAS (Service Account)
# Estas credenciales se usan para firmar llamadas a Google APIs.
# Debe tener Domain-Wide Delegation habilitado en Google Workspace.
GOOGLE_SERVICE_ACCOUNT_EMAIL=service-account@project.iam.gserviceaccount.com
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# 2) CUENTA PARA DRIVE / DOCS / CARGAS / EDICION / EML EN DRIVE
# Usuario de Google Workspace que tiene acceso a carpetas y templates.
# Esta es la cuenta "de archivos" que comentaste.
GOOGLE_DRIVE_IMPERSONATED_USER=cuenta.archivos@tu-dominio.com
GOOGLE_DRIVE_ACCOUNT_EMAIL=cuenta.drive@tu-dominio.com

# Modo de autenticacion Drive:
# - service_account: usa GOOGLE_SERVICE_ACCOUNT_* (+ optional impersonation)
# - oauth: usa client_id/client_secret/refresh_token dedicados de Drive
GOOGLE_DRIVE_AUTH_MODE=service_account
GOOGLE_DRIVE_OAUTH_CLIENT_ID=
GOOGLE_DRIVE_OAUTH_CLIENT_SECRET=
GOOGLE_DRIVE_OAUTH_REDIRECT_URI=
GOOGLE_DRIVE_OAUTH_REFRESH_TOKEN=

# 3) CUENTA PARA ENVIO Y RECEPCION DE CORREOS
# Usuario de Google Workspace que enviara correos (Gmail API).
# Esta es la cuenta "de correo" que comentaste.
GOOGLE_GMAIL_IMPERSONATED_USER=cuenta.correo@tu-dominio.com
GOOGLE_GMAIL_USER_ID=me

# Modo de autenticacion Gmail:
# - service_account: usa GOOGLE_GMAIL_IMPERSONATED_USER + DWD
# - oauth: usa client_id/client_secret/refresh_token
GOOGLE_GMAIL_AUTH_MODE=service_account
GOOGLE_GMAIL_OAUTH_CLIENT_ID=
GOOGLE_GMAIL_OAUTH_CLIENT_SECRET=
# Si usaras OAuth directo en esta API, usa por ejemplo:
# http://localhost:3000/auth/gmail/callback
# (debe existir igual en Google Cloud Console)
GOOGLE_GMAIL_OAUTH_REDIRECT_URI=
GOOGLE_GMAIL_OAUTH_REFRESH_TOKEN=

# ------------------------------------------------------------
# DRIVE / DOCS (IDs necesarios)
# ------------------------------------------------------------
# Carpeta padre donde se crearan las carpetas por folio (opcional)
GOOGLE_DRIVE_PARENT_FOLDER_ID=
# ID del template Google Docs para Orden de Trabajo (OT)
GOOGLE_OT_TEMPLATE_DOC_ID=
# ID del template Google Docs para Orden de Servicio (OS)
GOOGLE_OS_TEMPLATE_DOC_ID=

# ------------------------------------------------------------
# DETALLE EXACTO: DESDE DONDE SE ENVIA Y DONDE SE GUARDA
# ------------------------------------------------------------
# ENVIO DE CORREO:
# - El API envia correos DESDE la cuenta definida en:
#   GOOGLE_GMAIL_IMPERSONATED_USER
# - Esa cuenta debe tener permitido Gmail API + Delegacion en Workspace.
#
# GUARDADO DE ARCHIVOS (DRIVE/DOCS):
# - El API crea carpetas/sube archivos usando la cuenta definida en:
#   GOOGLE_DRIVE_IMPERSONATED_USER
# - Esa cuenta necesita permisos sobre:
#   1) GOOGLE_DRIVE_PARENT_FOLDER_ID (si lo usas)
#   2) GOOGLE_OT_TEMPLATE_DOC_ID y GOOGLE_OS_TEMPLATE_DOC_ID
#
# RUTA DE GUARDADO ACTUAL EN DRIVE:
# - Endpoint /contracts/upload-pdf:
#   crea carpeta nueva dentro de GOOGLE_DRIVE_PARENT_FOLDER_ID
#   y guarda ahi el PDF recibido.
# - Endpoint /contracts/process:
#   crea carpeta "<folio_digital>_docs" en:
#   - tab_contratos.iddrive (si existe en SQL), o
#   - GOOGLE_DRIVE_PARENT_FOLDER_ID (fallback).
#   Luego guarda OT.pdf y OS.pdf en esa carpeta.
#
# NOTA:
# - Hoy el proyecto ya envia correos con adjunto PDF.
# - El proyecto guarda tambien el .eml del correo en la misma carpeta del folio.
# - Nombre de archivos guardados por documento:
#   <folio>_OT.pdf, <folio>_OT.eml, <folio>_OS.pdf, <folio>_OS.eml

# Detector automatico de correo entrante (sin IMAP)
GMAIL_DETECTOR_ENABLED=true
GMAIL_DETECT_INTERVAL_MS=15000
GMAIL_DETECT_MAX_RESULTS=50
GMAIL_DETECT_WARMUP_SKIP_EXISTING=true
# Espera aleatoria antes de contestar (reenviar) un reply valido detectado
# Default: 10 a 30 minutos
GMAIL_REPLY_DELAY_MIN_MS=600000
GMAIL_REPLY_DELAY_MAX_MS=1800000

# IA para redaccion random controlada y resumen/escaneo documental (Cursor + Sonnet)
# API key (formato recomendado: CURSOR_API_KEY=sk-...)
CURSOR_API_KEY=
# URL estilo Anthropic Messages (por defecto se usa esta si no defines nada)
CURSOR_API_URL=https://api.anthropic.com/v1/messages
# Modelo recomendado por defecto
CURSOR_MODEL=claude-sonnet-4-6
# Opcional por tipo de documento
CURSOR_MODEL_OT=
CURSOR_MODEL_OS=
# Timeout general para llamadas de IA
AI_TIMEOUT_MS=15000
# Reglas estrictas:
# true = si IA falla o no es fiel al contrato, el endpoint falla (sin fallback)
# false = permite fallback controlado
AI_STRICT_MODE=true
